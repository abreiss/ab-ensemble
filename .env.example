# Copy this file to `.env` (git-ignored) and fill in your real values.
#   cp .env.example .env
#
# The backend loads `.env` on startup (see spring.config.import in
# src/main/resources/application.yml) and reads the values from these variables.
# Do NOT commit `.env` — only this example belongs in git.

ENSEMBLE_ANTHROPIC_API_KEY=<your-anthropic-api-key>

# Signup/invite passcode (issue #14; formerly the login passcode from Spec 07).
# Gates POST /api/accounts only -- existing accounts still log in via
# POST /api/auth without it. A blank value leaves signup closed (no new
# accounts); pick any demo invite code.
ENSEMBLE_PASSCODE=<your-demo-passcode>

# HMAC key for signing session tokens. If left blank, the key is derived from
# ENSEMBLE_PASSCODE. Since ENSEMBLE_PASSCODE is now a SHARED signup/invite code,
# leaving this blank means every invited user knows the signing key and could
# forge session tokens for arbitrary userIds. Set a distinct value here --
# especially before per-user data scoping (#15). Local dev keeps the fallback
# and only logs a loud startup warning while it is unset -- but under the deploy
# ("cloud") profile a blank value is FAIL-CLOSED: the app refuses to start, so
# every deployed environment MUST set a distinct ENSEMBLE_SESSION_SECRET.
ENSEMBLE_SESSION_SECRET=

# Seed account (issue #14). If BOTH are set, a default account is created on
# startup (idempotent; bypasses the signup passcode) so you can log in without
# an invite code. Leave blank to skip seeding. Never commit real values.
ENSEMBLE_SEED_USERNAME=demo_user
ENSEMBLE_SEED_PASSWORD=

# One-time data cleanup (spec #15). Opt-in, default OFF. When "true", a startup
# runner deletes every pre-existing "unowned" row (items/outfits written before
# per-user ownership, so they carry no userId) and each such item's photo, while
# leaving owned rows and the reserved usage#<date> counters untouched. It is
# idempotent and safe to re-run. Flip to "true" for a single boot to clear legacy
# data, then set it back to "false". Leave "false" (or blank) normally.
ENSEMBLE_MIGRATION_PURGE_UNOWNED=false

# Deploy-only (Spec 09). Local dev needs none of these — the defaults below
# already give disk photo storage + DynamoDB Local. App Runner sets them via
# Terraform, not this file.

# Which PhotoStorage bean is active: "disk" (default, local dev) or "s3"
# (deploy). Leave blank/unset locally.
ENSEMBLE_PHOTOS_BACKEND=

# S3 bucket for photos; only read when ENSEMBLE_PHOTOS_BACKEND=s3.
ENSEMBLE_PHOTOS_S3_BUCKET=

# DynamoDB endpoint override. Set to DynamoDB Local's URL for local dev
# (already the default); leave blank at deploy so DynamoDbConfig talks to
# real AWS DynamoDB via the default credential provider chain.
ENSEMBLE_DYNAMODB_ENDPOINT=

# Wardrobe items table name; defaults to "ensemble-items" if unset.
ENSEMBLE_DYNAMODB_TABLE_NAME=
